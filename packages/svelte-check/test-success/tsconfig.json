{
    "compilerOptions": {
        "target": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "allowJs": true,
        "checkJs": true,
        "skipLibCheck": true,
        "paths": {
            "$lib/*": ["./src/lib/*"]
        }
    },
    "include": ["./**/*"]
}
